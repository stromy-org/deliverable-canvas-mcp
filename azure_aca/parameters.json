{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "subscriptionId": {
            "value": "YOUR_SUBSCRIPTION_ID"
        },
        "name": {
            "value": "deliverable-canvas-mcp"
        },
        "location": {
            "value": "westeurope"
        },
        "environmentId": {
            "value": "/subscriptions/YOUR_SUBSCRIPTION_ID/resourceGroups/rg-deliverable-canvas-mcp/providers/Microsoft.App/managedEnvironments/mcp-env"
        },
        "containers": {
            "value": [
                {
                    "name": "deliverable-canvas-mcp",
                    "image": "mcr.microsoft.com/k8se/quickstart:latest",
                    "command": [],
                    "args": [],
                    "resources": {
                        "cpu": "0.25",
                        "memory": ".5Gi"
                    }
                }
            ]
        },
        "registries": {
            "value": []
        },
        "secrets": {
            "value": {
                "arrayValue": []
            }
        },
        "ingress": {
            "value": {
                "external": true,
                "transport": "Auto",
                "allowInsecure": false,
                "targetPort": 8080,
                "stickySessions": {
                    "affinity": "none"
                },
                "additionalPortMappings": []
            }
        },
        "environmentName": {
            "value": "mcp-env"
        },
        "workspaceName": {
            "value": "mcp-workspace"
        },
        "workspaceLocation": {
            "value": "westeurope"
        }
    }
}
