FASTMCP_TRANSPORT=http
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8000
MCP_DEV_MODE=false
LOG_LEVEL=INFO

# Production (Azure Container Apps) values are set in the Dockerfile, not here:
#   FASTMCP_TRANSPORT=streamable-http
#   FASTMCP_HOST=0.0.0.0
#   FASTMCP_PORT=8080

# ---------- OAuth (Microsoft Entra ID via FastMCP AzureProvider) ----------
# OAUTH_REQUIRED_SCOPES is whitespace-delimited per OAuth 2.0 (RFC 6749).
# `offline_access` is REQUIRED — without it the Claude app's connector has no
# refresh token and surfaces "Reconnect" every ~1h when the access token expires.
OAUTH_ENABLE=true
OAUTH_REQUIRED_SCOPES="mcp.access offline_access"
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TENANT_ID=
OAUTH_BASE_URL=
