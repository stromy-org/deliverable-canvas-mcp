{
  "permissions": {
    "allow": [
      "Bash(az account show:*)",
      "Bash(az ad app list:*)",
      "Bash(az ad app show:*)",
      "Bash(az ad sp show:*)",
      "Bash(az ad sp list:*)",
      "Bash(az ad sp create --id *)",
      "Bash(az ad app permission add --id * --api * --api-permissions *)",
