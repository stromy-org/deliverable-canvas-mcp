      "Bash(az containerapp show --name deliverable-canvas-mcp --resource-group rg-deliverable-canvas-mcp-ne:*)",
      "Bash(az containerapp list:*)",
      "Bash(az containerapp revision list --name deliverable-canvas-mcp --resource-group rg-deliverable-canvas-mcp-ne:*)",
      "Bash(az containerapp logs show --name deliverable-canvas-mcp --resource-group rg-deliverable-canvas-mcp-ne:*)",
      "Bash(az containerapp update --name deliverable-canvas-mcp --resource-group rg-deliverable-canvas-mcp-ne --set-env-vars *)",
      "Bash(az containerapp update --name deliverable-canvas-mcp --resource-group rg-deliverable-canvas-mcp-ne --remove-env-vars *)"
    ]
  }
}
