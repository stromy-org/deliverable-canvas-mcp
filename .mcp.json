{
  "mcpServers": {
    "deliverable-canvas-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "python", "-m", "src.server"],
      "env": {
        "FASTMCP_TRANSPORT": "stdio"
      }
    },
    "deliverable-canvas-mcp-http": {
      "type": "http",
      "url": "http://127.0.0.1:8000/mcp"
    }
  }
}
